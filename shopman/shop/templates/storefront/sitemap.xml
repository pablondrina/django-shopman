{% autoescape off %}<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1">
{% for url in urls %}  <url>
    <loc>{{ url.loc }}</loc>
    {% if url.lastmod %}<lastmod>{{ url.lastmod }}</lastmod>
    {% endif %}<changefreq>{{ url.changefreq }}</changefreq>
    <priority>{{ url.priority }}</priority>
    {% if url.image_url %}<image:image>
      <image:loc>{{ url.image_url }}</image:loc>
      {% if url.image_title %}<image:title>{{ url.image_title }}</image:title>{% endif %}
    </image:image>
    {% endif %}</url>
{% endfor %}</urlset>
{% endautoescape %}
