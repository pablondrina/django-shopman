# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (default: SQLite — override for PostgreSQL in production)
# DATABASE_URL=postgres://user:pass@localhost:5432/shopman

# Stock backend (auto-detect Stockman if installed, otherwise Noop)
# SHOPMAN_STOCK_BACKEND=shopman.stock.adapters.stockman.StockmanBackend

# Payment backend (default: MockPaymentBackend)
# SHOPMAN_PAYMENT_BACKEND=shopman.payment.adapters.mock.MockPaymentBackend

# Accounting backend (default: MockAccountingBackend)
# SHOPMAN_ACCOUNTING_BACKEND=shopman.accounting.backends.mock.MockAccountingBackend

# Fiscal backend (default: MockFiscalBackend)
# SHOPMAN_FISCAL_BACKEND=shopman.fiscal.backends.mock.MockFiscalBackend

# Manychat (optional — notifications)
# MANYCHAT_API_TOKEN=
# MANYCHAT_FLOW_MAP={}
