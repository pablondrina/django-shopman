# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (default: SQLite — override for PostgreSQL in production)
# DATABASE_URL=postgres://user:pass@localhost:5432/shopman

# Inventory backend (auto-detect Stockman if installed, otherwise Noop)
# SHOPMAN_STOCK_BACKEND=shopman.inventory.adapters.stockman.StockmanBackend

# Payment backend (default: MockPaymentBackend)
# SHOPMAN_PAYMENT_BACKEND=shopman.payment.adapters.mock.MockPaymentBackend

# Accounting backend (default: MockAccountingBackend)
# SHOPMAN_ACCOUNTING_BACKEND=shopman.accounting.backends.mock.MockAccountingBackend

# Fiscal backend (default: MockFiscalBackend)
# SHOPMAN_FISCAL_BACKEND=shopman.fiscal.backends.mock.MockFiscalBackend

# Manychat (WhatsApp notifications)
# MANYCHAT_API_TOKEN=           # API token from ManyChat Settings → API
# MANYCHAT_OTP_FLOW_NS=         # Flow namespace for OTP template (e.g. content20250401_123456)
# MANYCHAT_WEBHOOK_SECRET=      # HMAC secret for webhook signature validation

# WhatsApp Bot (F15 — Meta Cloud API for inbound messages)
# WHATSAPP_VERIFY_TOKEN=        # Verify token for webhook setup
# WHATSAPP_STOREFRONT_URL=      # Base URL sent in access links (e.g. https://padaria.com)

# iFood (Marketplace F16)
# IFOOD_WEBHOOK_TOKEN=          # Token for iFood webhook authentication
# IFOOD_MERCHANT_ID=            # iFood merchant ID
