# ── Django ────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
SHOPMAN_ENVIRONMENT=development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000
PORT=8000

# ── Instância ativa ───────────────────────────────────────────────────
# Nelson carrega o comando `seed` e as estratégias de cliente.
SHOPMAN_INSTANCE_APPS=nelson
SHOPMAN_CUSTOMER_STRATEGY_MODULES=nelson.customer_strategies
# Optional idempotent contact bootstrap for:
# python manage.py configure_shop_contact
# SHOPMAN_SHOP_NAME=Nelson Boulangerie
# SHOPMAN_SHOP_PHONE=554333231997
# SHOPMAN_SHOP_EMAIL=nelson@boulangerie.com.br
# SHOPMAN_SHOP_WHATSAPP=https://wa.me/554333231997

# ── Release readiness evidence ───────────────────────────────────────
# SHOPMAN_PREPROD_URL=https://staging.example.com
# SHOPMAN_MANUAL_QA_EVIDENCE=/app/reports/manual-qa.md

# ── Database ──────────────────────────────────────────────────────────
# Postgres é o default de dev — casa com docker-compose (make up).
# Deixe comentado para cair no fallback SQLite (útil para CI leve / scripts).
DATABASE_URL=postgres://shopman:shopman@localhost:5432/shopman
POSTGRES_DB=shopman
POSTGRES_USER=shopman
POSTGRES_PASSWORD=shopman
# Staging/prod pequenos podem precisar fechar conexões por request para não
# esgotar o limite do PostgreSQL gerenciado. Default do código: 60.
# DATABASE_CONN_MAX_AGE=0

# ── Redis ─────────────────────────────────────────────────────────────
# Cache compartilhado para django-ratelimit + caches operacionais + SSE multi-worker.
# Obrigatório em staging/prod. Comente só para fallback local leve.
REDIS_URL=redis://localhost:6379/0

# ── Static/media ──────────────────────────────────────────────────────
# Docker/release usa STATIC_ROOT para collectstatic. Reverse proxy/CDN deve
# servir esse diretório em staging/prod; Django não é o servidor de estáticos.
# STATIC_ROOT=/app/staticfiles

# ── Shopman adapters (payment) ────────────────────────────────────────
# Per-method PIX / card adapter. Defaults to the in-process mock backend;
# override per environment. When left on payment_mock, the mock PIX flow
# schedules a mock_pix.confirm directive that runs the same confirm_pix
# service as the real EFI webhook — dev parity is enforced by code path.
# SHOPMAN_PIX_ADAPTER=shopman.shop.adapters.payment_efi
# SHOPMAN_CARD_ADAPTER=shopman.shop.adapters.payment_stripe
#
# Staging/POS real gateway profile:
# SHOPMAN_ENVIRONMENT=staging
# SHOPMAN_PIX_ADAPTER=shopman.shop.adapters.payment_efi
# SHOPMAN_CARD_ADAPTER=shopman.shop.adapters.payment_stripe
# SHOPMAN_FISCAL_ADAPTER=shopman.shop.adapters.fiscal_focusnfe.FocusNFeBackend

# PIX intent expiry (in seconds).
# SHOPMAN_PIX_EXPIRY_SECONDS=3600

# ── EFI (real PIX backend) ────────────────────────────────────────────
# EFI_SANDBOX=true
# EFI_CLIENT_ID=
# EFI_CLIENT_SECRET=
# EFI_CERTIFICATE_PATH=
# EFI_PIX_KEY=
# EFI_WEBHOOK_TOKEN=          # Shared secret with EFI dashboard (required)
# EFI_MTLS_HEADER=HTTP_X_SSL_CLIENT_VERIFY

# ── Stripe (card backend) ─────────────────────────────────────────────
# Staging/test keys must use pk_test_ / sk_test_. Live keys are blocked by
# smoke-gateways-sandbox outside production.
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=
# STRIPE_CAPTURE_METHOD=manual

# ── Fiscal / Accounting (optional) ────────────────────────────────────
# Dotted path to a FiscalBackend class. Leave unset to disable NFC-e emission.
# SHOPMAN_FISCAL_ADAPTER=shopman.shop.adapters.fiscal_focusnfe.FocusNFeBackend
# FOCUS_NFE_ENVIRONMENT=homologacao
# Token Focus NFe homolog/prod. Adapter uses HTTP Basic Auth with token as username and blank password.
# FOCUS_NFE_TOKEN=
# Optional override. When empty, Focus NFe uses Shop.document from the establishment profile.
# FOCUS_NFE_CNPJ_EMITENTE=
# FOCUS_NFE_NFCE_SERIE=
# FOCUS_NFE_NFCE_COMPLETA=1
# FOCUS_NFE_NFCE_LOCAL_DESTINO=1
# FOCUS_NFE_NFCE_PRESENCA_COMPRADOR=1
# FOCUS_NFE_NFCE_MODALIDADE_FRETE=9
# FOCUS_NFE_NATUREZA_OPERACAO=VENDA AO CONSUMIDOR
# FOCUS_NFE_NFCE_DEFAULT_CFOP=5102
# FOCUS_NFE_BASE_URL=        # leave empty; homologação resolves to Focus homolog URL
# FOCUS_NFE_TIMEOUT=30
# SHOPMAN_POS_DISCOUNT_APPROVAL_THRESHOLD_Q=0
# GUESTMAN_ORDER_HISTORY_BACKEND=shopman.guestman.adapters.orderman.OrdermanOrderHistoryBackend
# SHOPMAN_ACCOUNTING_BACKEND=nelson.adapters.accounting.InternalAccountingBackend

# ── ManyChat (WhatsApp notifications) ─────────────────────────────────
# WhatsApp is delivered via ManyChat flows — NOT Meta Cloud API directly.
# MANYCHAT_API_TOKEN=           # API token from ManyChat Settings → API
# MANYCHAT_OTP_FLOW_NS=         # Flow namespace for OTP template (e.g. content20250401_123456)
# MANYCHAT_WEBHOOK_SECRET=      # HMAC secret for webhook signature validation

# ── Doorman (passwordless auth / access links) ────────────────────────
# Required outside DEBUG for server-to-server access link creation.
# DOORMAN_ACCESS_LINK_API_KEY=

# ── WhatsApp Bot (inbound messages — Meta Cloud API) ──────────────────
# WHATSAPP_VERIFY_TOKEN=        # Verify token for webhook setup
# WHATSAPP_STOREFRONT_URL=      # Base URL sent in access links (e.g. https://padaria.com)

# ── iFood (marketplace) ───────────────────────────────────────────────
# IFOOD_WEBHOOK_TOKEN=          # Token for iFood webhook authentication
# IFOOD_MERCHANT_ID=            # iFood merchant ID
