{
  "name": "shopman-storefront",
  "version": "1.0.0",
  "private": true,
  "description": "Shopman storefront CSS build pipeline",
  "scripts": {
    "css:build": "tailwindcss -i ./static/src/input.css -o ./channels/web/static/storefront/css/output.css --minify",
    "css:watch": "tailwindcss -i ./static/src/input.css -o ./channels/web/static/storefront/css/output.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15"
  }
}
