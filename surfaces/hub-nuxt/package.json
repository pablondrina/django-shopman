{
  "name": "hub-nuxt",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --host 127.0.0.1 --port 3001",
    "generate": "nuxt generate",
    "preview": "HOST=127.0.0.1 nuxt preview --port 3001",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:component": "vitest run --project component",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"app/**/*.{ts,vue}\" \"tests/**/*.ts\"",
    "typecheck": "nuxi typecheck",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.2",
    "@nuxtjs/color-mode": "^4.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "motion-v": "^2.2.1",
    "nuxt": "^4.4.5",
    "reka-ui": "^2.9.7",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34",
    "vue-router": "^5.0.6",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.109",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.61.1",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.14",
    "vue-tsc": "^3.0.0"
  }
}
